// Chrome do BasedBrowser. Entra no Rust via re-export inline da macro
// `slint::slint!(export { MainWindow, .. } from "../ui/app.slint")` — SEM build.rs (L-007:
// `include_modules!()` injeta o gerado como fonte do crate → 640 erros nos lints `deny`; a macro
// de crate externo é isenta do clippy). Decodifica eventos a primitivos; a tradução para
// `InputEvent` do Servo mora no Rust (`input.rs`).
//
// M9 (ADR-0012): redesign "dark refinado". Tokens centralizados em `global Theme` (espelham
// `.specs/features/m9-redesign-ui/spec.md` e o mock em `designs/based-browser.pen`). Botões em
// ÍCONE (`IconBtn`), omnibox arredondada com cadeado, abas-pílula, e o menu overflow `⋯` que
// recolhe Histórico/Limpar/DevTools/Zoom/Find. A função (props/callbacks) é a do M2–M7; o M9 só
// muda o VISUAL e ADICIONA affordances (sem regredir).
import { Button, LineEdit, ListView, ScrollView } from "std-widgets.slint";

// Uma aba na barra de abas (M4). O Rust constrói um `VecModel<TabInfo>` a partir do `TabManager`
// (fonte da verdade) e o entrega à propriedade `tabs`. `active` destaca a aba atual. `icon` (M9):
// favicon da página (vazio até o Servo entregar via `notify_favicon_changed`).
export struct TabInfo {
    title: string,
    active: bool,
    icon: image,
}

// Um favorito na barra de favoritos (M4). O Rust constrói um `VecModel<BookmarkInfo>` a partir do
// `AppData` (persistido em ~/.config/basedbrowser/bookmarks.json) e o entrega à propriedade `bookmarks`.
export struct BookmarkInfo {
    title: string,
    url: string,
}

// Uma entrada de histórico (M4) — usada tanto no painel de histórico quanto no autocomplete da barra.
// O Rust filtra/ordena (mais recente primeiro) e entrega via `history` (painel) e `suggestions` (barra).
export struct HistoryItem {
    title: string,
    url: string,
}

// M7 (ADR-0010): painel de devtools. Linha de console (nível + texto) e linha de rede (req+resp,
// headers/payload já achatados em string pelo Rust — Slint não modela bem listas de tuplas aninhadas).
export struct DevConsoleLine {
    level: string,
    text: string,
}

export struct DevNetRow {
    method: string,
    url: string,
    status: string,
    mime: string,
    req-headers: string,
    resp-headers: string,
    body: string,
}

// M9: tokens do tema "dark refinado" (fonte da verdade compartilhada com o mock do Pencil).
global Theme {
    out property <color> bg-base: #0f0f14;
    out property <color> bg-surface: #15151b;
    out property <color> bg-surface-2: #1e1e26;
    out property <color> bg-elevated: #2a2a3a;
    out property <color> accent: #6c5ce7;
    out property <color> accent-soft: #6c5ce733;
    out property <color> text-hi: #f0f0f5;
    out property <color> text-mid: #9a9aa6;
    out property <color> text-lo: #6a6a7a;
    out property <color> border: #2a2a38;
    out property <color> danger: #ff6b6b;
    out property <color> ok: #5dd1a0;
    out property <length> radius-pill: 8px;
    out property <length> radius-btn: 6px;
    out property <length> radius-panel: 12px;
}

// M9: botão em ícone (glifo de texto), com estados enabled/hover/disabled. Reusado em toda a barra
// (nav ‹ › ⟳, ★, ⋯, +, × das pílulas, controles de zoom/find).
component IconBtn inherits Rectangle {
    in property <string> glyph;
    in property <bool> enabled: true;
    in property <length> glyph-size: 18px;
    in property <color> glyph-color: Theme.text-hi;
    in property <color> hover-bg: Theme.bg-elevated;
    callback clicked();
    width: 34px;
    height: 34px;
    border-radius: Theme.radius-btn;
    background: root.enabled && touch.has-hover ? root.hover-bg : transparent;
    animate background { duration: 90ms; }
    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    Text {
        width: 100%;
        height: 100%;
        horizontal-alignment: center;
        vertical-alignment: center;
        text: root.glyph;
        font-size: root.glyph-size;
        color: root.enabled ? root.glyph-color : Theme.text-lo;
    }
}

// M9: cadeado da omnibox desenhado (monocromático, respeita o tema) — fechado/ok p/ https,
// neutro p/ http. Arco (anel) + corpo sólido sobreposto formam o glifo.
component LockIcon inherits Rectangle {
    in property <bool> secure;
    width: 14px;
    height: 14px;
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: 0;
        width: 8px;
        height: 9px;
        border-radius: 4px;
        border-width: 1.5px;
        border-color: root.secure ? Theme.ok : Theme.text-mid;
        background: transparent;
    }
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: 5px;
        width: 11px;
        height: 9px;
        border-radius: 2px;
        background: root.secure ? Theme.ok : Theme.text-mid;
    }
}

// M9: item do menu overflow `⋯` — rótulo + dica de atalho à direita; hover em accent-soft.
component MenuItem inherits Rectangle {
    in property <string> label;
    in property <string> hint;
    callback clicked();
    height: 34px;
    border-radius: Theme.radius-btn;
    background: touch.has-hover ? Theme.accent-soft : transparent;
    animate background { duration: 90ms; }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 12px;
        Text {
            text: root.label;
            font-size: 13px;
            color: Theme.text-hi;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        Text {
            text: root.hint;
            font-size: 12px;
            color: Theme.text-lo;
            vertical-alignment: center;
        }
    }
}

// Chrome do M2/M4/M7 repaginado no M9: barra de abas + toolbar (omnibox) + favoritos + área web.
// O `.slint` apenas DECODIFICA cada evento para primitivos e chama um callback; a tradução
// primitivo -> `InputEvent` do Servo mora no Rust (`input.rs`). Coordenadas: declarar os params como
// `physical-length` faz o Slint converter logical -> físico pelo scale factor, e como a Image usa
// `image-fit: fill` sobre um contexto do Servo do MESMO tamanho da área web, o mapeamento é
// identidade (physical-px == device-px do Servo). Sem matemática de letterbox.
export component MainWindow inherits Window {
    // Dirigidas pelo Rust (pipeline de frame + WebViewDelegate).
    in property <image> frame;
    in property <string> page-url;
    in property <bool> loading;
    in property <bool> can-go-back;
    in property <bool> can-go-forward;
    in property <string> window-title: "BasedBrowser";
    // M9: URL atual é https (cadeado fechado) — derivado no Rust (sync_chrome).
    in property <bool> page-secure: false;
    // M9: zoom da aba ativa em % (inteiro) — mostrado no menu ⋯.
    in property <int> zoom-percent: 100;
    // M4: lista de abas (derivada do TabManager no Rust).
    in property <[TabInfo]> tabs;
    // M4: lista de favoritos (derivada do AppData no Rust).
    in property <[BookmarkInfo]> bookmarks;
    // M4: histórico filtrado p/ o painel + sugestões de autocomplete da barra (ambos do Rust).
    in property <[HistoryItem]> history;
    in property <[HistoryItem]> suggestions;
    // Visibilidade do painel de histórico (alternada pelo menu ⋯; o Rust também pode fechá-lo).
    in-out property <bool> history-open: false;
    // M9: menu overflow ⋯ (recolhe Histórico/Limpar/DevTools/Zoom/Find).
    in-out property <bool> menu-open: false;
    // M9: find-in-page (Ctrl+F / menu ⋯). count=total de ocorrências, index=atual (1-based).
    in-out property <bool> find-open: false;
    in property <int> find-count: 0;
    in property <int> find-index: 0;
    // M7 (ADR-0010): painel de devtools (console/eval + rede). Models e status vêm do Rust.
    in property <[DevConsoleLine]> dev-console;
    in property <[DevNetRow]> dev-net;
    in property <string> dev-status: "";
    in-out property <bool> devtools-open: false;
    in-out property <int> dev-tab: 0; // 0 = console, 1 = rede
    in-out property <int> dev-net-sel: -1; // linha de rede selecionada (detalhe)

    // Chrome -> Rust.
    callback load-url(string);
    callback go-back();
    callback go-forward();
    callback reload();
    // M4: ciclo de vida das abas (índice 0-based na lista `tabs`).
    callback new-tab();
    callback select-tab(int);
    callback close-tab(int);
    // M4: favoritos (★ adiciona a página atual; open/remove por índice na lista `bookmarks`).
    callback add-bookmark();
    callback open-bookmark(int);
    callback remove-bookmark(int);
    // M4: histórico. toggle-history abre/atualiza o painel; search-history filtra; open-history abre
    // a entrada `history[i]`. url-edited alimenta o autocomplete; open-suggestion abre `suggestions[i]`.
    callback toggle-history();
    callback search-history(string);
    callback open-history(int);
    callback url-edited(string);
    callback open-suggestion(int);
    // M6: limpar dados de navegação (cookies + Web Storage do Servo + nosso histórico; preserva
    // favoritos e a sessão de abas).
    callback clear-browsing-data();
    // M7: devtools. toggle-devtools (re)abre o painel (Rust atualiza os models); dev-eval roda JS na
    // aba ativa; clear-devtools limpa os buffers de console/rede.
    callback toggle-devtools();
    callback dev-eval(string);
    callback clear-devtools();
    // M9: zoom de página (Ctrl +/−/0 e o menu ⋯).
    callback zoom-in();
    callback zoom-out();
    callback zoom-reset();
    // M9: find-in-page. find-in-page(query, forward) busca/navega; find-close limpa os destaques.
    callback find-in-page(string, bool);
    callback find-close();
    // M9: foco da omnibox (Ctrl+L) — o Rust invoca; tratado internamente no Slint (handler abaixo).
    callback focus-url-bar();
    // Input -> Rust. pointer: (x, y, kind, button); kind 0=down 1=up 2=move; button 0=left
    // 1=right 2=middle 3=outro. scroll: (x, y, delta-x, delta-y). key: (text, pressed, ctrl,
    // shift, alt, meta, repeat). web-resized: novo tamanho FÍSICO da área web.
    callback forward-pointer(physical-length, physical-length, int, int);
    callback forward-scroll(physical-length, physical-length, length, length);
    callback forward-key(string, bool, bool, bool, bool, bool, bool);
    callback web-resized(physical-length, physical-length);

    title: root.window-title;
    preferred-width: 1024px;
    preferred-height: 768px;
    background: Theme.bg-base;

    // M9: Ctrl+L (Rust invoca `focus-url-bar`) → foca a omnibox.
    focus-url-bar => {
        omni-input.focus();
    }

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // Barra de abas (M4/M9): pílulas com favicon + título (elide) + × no hover; aba ativa
        // elevada (bg-elevated) com contorno de accent. Botão + discreto à direita.
        Rectangle {
            background: Theme.bg-surface;
            height: 42px;
            HorizontalLayout {
                padding: 8px;
                padding-bottom: 0;
                spacing: 6px;
                for tab[idx] in root.tabs : Rectangle {
                    width: 188px;
                    height: 34px;
                    border-radius: Theme.radius-pill;
                    background: tab.active ? Theme.bg-elevated : transparent;
                    border-width: 1px;
                    border-color: tab.active ? Theme.accent : transparent;
                    select := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.select-tab(idx); }
                    }
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 4px;
                        spacing: 8px;
                        // Favicon (M9): dot placeholder neutro + Image por cima (imagem vazia não
                        // renderiza → o dot aparece; quando o Servo entrega o favicon, ele cobre o dot).
                        Rectangle {
                            width: 15px;
                            height: 15px;
                            border-radius: 4px;
                            background: tab.active ? Theme.accent : Theme.text-lo;
                            Image {
                                width: 100%;
                                height: 100%;
                                image-fit: contain;
                                source: tab.icon;
                            }
                        }
                        Text {
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                            color: tab.active ? Theme.text-hi : Theme.text-mid;
                            overflow: elide;
                            font-size: 13px;
                            text: tab.title == "" ? "Nova aba" : tab.title;
                        }
                        IconBtn {
                            width: 22px;
                            height: 22px;
                            glyph: "×";
                            glyph-size: 16px;
                            glyph-color: Theme.text-mid;
                            hover-bg: #4a4a5e;
                            clicked => { root.close-tab(idx); }
                        }
                    }
                }
                IconBtn {
                    width: 30px;
                    height: 30px;
                    glyph: "+";
                    glyph-size: 18px;
                    glyph-color: Theme.text-mid;
                    clicked => { root.new-tab(); }
                }
                // Empurra as abas para a esquerda (não esticam para preencher a barra).
                Rectangle { horizontal-stretch: 1; }
            }
        }

        // Toolbar (M9): nav em ícone ‹ › ⟳ + omnibox arredondada (cadeado + URL + ★) + menu ⋯.
        Rectangle {
            background: Theme.bg-surface;
            height: 52px;
            HorizontalLayout {
                padding: 8px;
                spacing: 6px;
                IconBtn {
                    glyph: "‹";
                    glyph-size: 24px;
                    enabled: root.can-go-back;
                    clicked => { root.go-back(); }
                }
                IconBtn {
                    glyph: "›";
                    glyph-size: 24px;
                    enabled: root.can-go-forward;
                    clicked => { root.go-forward(); }
                }
                IconBtn {
                    glyph: "⟳";
                    glyph-size: 19px;
                    clicked => { root.reload(); }
                }
                // Omnibox: campo arredondado com cadeado, TextInput (sem chrome do std) e ★.
                Rectangle {
                    horizontal-stretch: 1;
                    background: Theme.bg-surface-2;
                    border-radius: Theme.radius-pill;
                    border-width: 1px;
                    border-color: omni-input.has-focus ? Theme.accent : Theme.border;
                    animate border-color { duration: 120ms; }
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 4px;
                        spacing: 8px;
                        LockIcon {
                            secure: root.page-secure;
                        }
                        // Wrapper p/ sobrepor o placeholder quando vazio (TextInput não tem placeholder).
                        Rectangle {
                            horizontal-stretch: 1;
                            omni-input := TextInput {
                                width: 100%;
                                height: 100%;
                                vertical-alignment: center;
                                color: Theme.text-hi;
                                font-size: 13px;
                                single-line: true;
                                // edited → autocomplete; accepted (Enter) → carrega e limpa as sugestões.
                                text: root.page-url;
                                accepted => { root.load-url(self.text); root.url-edited(""); }
                                edited => { root.url-edited(self.text); }
                            }
                            if omni-input.text == "" : Text {
                                x: 0;
                                height: 100%;
                                vertical-alignment: center;
                                color: Theme.text-lo;
                                font-size: 13px;
                                text: "Pesquisar ou digitar uma URL";
                            }
                        }
                        IconBtn {
                            width: 28px;
                            height: 28px;
                            glyph: "★";
                            glyph-size: 15px;
                            glyph-color: Theme.accent;
                            hover-bg: Theme.bg-elevated;
                            clicked => { root.add-bookmark(); }
                        }
                    }
                }
                IconBtn {
                    glyph: "⋯";
                    glyph-size: 22px;
                    clicked => { root.menu-open = !root.menu-open; }
                }
            }
        }

        // Indicador de loading (M9): barra fina de accent sob a toolbar (substitui o texto "carregando").
        Rectangle {
            height: 2px;
            background: root.loading ? Theme.accent : transparent;
            animate background { duration: 120ms; }
        }

        // Barra de favoritos (M4/M9): aparece só se há favoritos. Cada pílula abre na aba ativa; o ×
        // remove. Mesmo sistema visual das abas.
        if root.bookmarks.length > 0 : Rectangle {
            background: Theme.bg-surface;
            height: 34px;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                padding-bottom: 4px;
                spacing: 4px;
                for bm[idx] in root.bookmarks : Rectangle {
                    height: 26px;
                    min-width: 60px;
                    max-width: 200px;
                    border-radius: Theme.radius-btn;
                    background: bmtouch.has-hover ? Theme.bg-elevated : transparent;
                    bmtouch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.open-bookmark(idx); }
                    }
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 3px;
                        spacing: 6px;
                        Rectangle {
                            width: 12px;
                            height: 12px;
                            border-radius: 3px;
                            background: Theme.text-mid;
                        }
                        Text {
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                            overflow: elide;
                            color: Theme.text-mid;
                            font-size: 12px;
                            text: bm.title == "" ? bm.url : bm.title;
                        }
                        IconBtn {
                            width: 18px;
                            height: 18px;
                            glyph: "×";
                            glyph-size: 13px;
                            glyph-color: Theme.text-lo;
                            hover-bg: #4a4a5e;
                            clicked => { root.remove-bookmark(idx); }
                        }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }

        // Area web: a Image exibe o frame do Servo; a TouchArea captura pointer/scroll e o
        // FocusScope captura teclado. `web-resized` dispara quando o layout muda o tamanho.
        web := Rectangle {
            vertical-stretch: 1;
            background: Theme.bg-surface-2;
            changed width => { root.web-resized(self.width, self.height); }
            changed height => { root.web-resized(self.width, self.height); }

            Image {
                width: 100%;
                height: 100%;
                image-fit: fill;
                source: root.frame;
            }
            fs := FocusScope {
                width: 100%;
                height: 100%;
                key-pressed(e) => {
                    root.forward-key(e.text, true, e.modifiers.control, e.modifiers.shift,
                        e.modifiers.alt, e.modifiers.meta, e.repeat);
                    accept
                }
                key-released(e) => {
                    root.forward-key(e.text, false, e.modifiers.control, e.modifiers.shift,
                        e.modifiers.alt, e.modifiers.meta, false);
                    accept
                }
                TouchArea {
                    width: 100%;
                    height: 100%;
                    pointer-event(e) => {
                        root.forward-pointer(
                            self.mouse-x,
                            self.mouse-y,
                            e.kind == PointerEventKind.down ? 0
                                : e.kind == PointerEventKind.up ? 1 : 2,
                            e.button == PointerEventButton.left ? 0
                                : e.button == PointerEventButton.right ? 1
                                : e.button == PointerEventButton.middle ? 2 : 3);
                        fs.focus();
                    }
                    scroll-event(e) => {
                        root.forward-scroll(self.mouse-x, self.mouse-y, e.delta-x, e.delta-y);
                        accept
                    }
                }
            }

            // Autocomplete (M4): sugestões de histórico ancoradas no topo da área web, enquanto se
            // digita na barra de URL. Some quando não há sugestões (Rust limpa no Enter / texto vazio).
            if root.suggestions.length > 0 : Rectangle {
                y: 0;
                x: 0;
                width: 100%;
                height: min(root.suggestions.length * 32px, 6 * 32px);
                background: #14141c;
                border-color: #33334a;
                border-width: 1px;
                VerticalLayout {
                    for s[idx] in root.suggestions : Rectangle {
                        height: 32px;
                        background: stouch.has-hover ? #24243a : transparent;
                        stouch := TouchArea {
                            clicked => { root.open-suggestion(idx); }
                        }
                        HorizontalLayout {
                            padding-left: 12px;
                            Text {
                                vertical-alignment: center;
                                color: #cfd2e6;
                                overflow: elide;
                                text: s.url;
                            }
                        }
                    }
                }
            }

            // Painel de histórico (M4): overlay sobre a área web com busca + lista (revisitar).
            if root.history-open : Rectangle {
                width: 100%;
                height: 100%;
                background: #0d0d12;
                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Histórico";
                            color: #ffffff;
                            font-size: 20px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: "Fechar";
                            clicked => { root.history-open = false; }
                        }
                    }
                    LineEdit {
                        placeholder-text: "Buscar no histórico...";
                        edited(t) => { root.search-history(t); }
                    }
                    ListView {
                        for h[idx] in root.history : Rectangle {
                            height: 34px;
                            background: htouch.has-hover ? #1c1c28 : transparent;
                            htouch := TouchArea {
                                clicked => { root.open-history(idx); }
                            }
                            HorizontalLayout {
                                padding-left: 10px;
                                spacing: 10px;
                                Text {
                                    width: 45%;
                                    vertical-alignment: center;
                                    color: #e6e6f0;
                                    overflow: elide;
                                    text: h.title == "" ? h.url : h.title;
                                }
                                Text {
                                    vertical-alignment: center;
                                    color: #8a8a9a;
                                    overflow: elide;
                                    text: h.url;
                                }
                            }
                        }
                    }
                }
            }

            // Painel de devtools (M7, ADR-0010): overlay sobre a área web. Aba Console (console.log ao
            // vivo + REPL de eval, in-process) e aba Rede (req+resp do cliente RDP, com detalhe de
            // headers/payload). Os models e o status vêm do Rust (setup_devtools).
            if root.devtools-open : Rectangle {
                width: 100%;
                height: 100%;
                background: #0d0d12;
                VerticalLayout {
                    padding: 14px;
                    spacing: 10px;
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "DevTools";
                            color: #ffffff;
                            font-size: 20px;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.dev-status;
                            color: #8a8a9a;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        Button {
                            text: root.dev-tab == 0 ? "● Console" : "Console";
                            clicked => { root.dev-tab = 0; }
                        }
                        Button {
                            text: root.dev-tab == 1 ? "● Rede" : "Rede";
                            clicked => { root.dev-tab = 1; }
                        }
                        Button {
                            text: "Limpar";
                            clicked => { root.clear-devtools(); }
                        }
                        Button {
                            text: "Fechar";
                            clicked => { root.devtools-open = false; }
                        }
                    }

                    // Aba CONSOLE: lista de mensagens + REPL de eval.
                    if root.dev-tab == 0 : VerticalLayout {
                        spacing: 8px;
                        ListView {
                            for c in root.dev-console : HorizontalLayout {
                                height: 22px;
                                padding-left: 8px;
                                spacing: 8px;
                                Text {
                                    text: c.level;
                                    width: 58px;
                                    vertical-alignment: center;
                                    color: c.level == "error" ? #ff8a8a
                                        : c.level == "warn" ? #ffd47a
                                        : c.level == "result" ? #8affc0
                                        : c.level == "eval" ? #9ab8ff
                                        : #9aa0b4;
                                }
                                Text {
                                    text: c.text;
                                    color: #e6e6f0;
                                    overflow: elide;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        LineEdit {
                            placeholder-text: "Avaliar JavaScript e teclar Enter (ex.: document.title)";
                            accepted(t) => { root.dev-eval(t); self.text = ""; }
                        }
                    }

                    // Aba REDE: lista de requisições + detalhe (headers/payload) da selecionada.
                    if root.dev-tab == 1 : VerticalLayout {
                        spacing: 8px;
                        ListView {
                            for n[idx] in root.dev-net : Rectangle {
                                height: 26px;
                                background: ntouch.has-hover || root.dev-net-sel == idx ? #1c1c28 : transparent;
                                ntouch := TouchArea {
                                    clicked => { root.dev-net-sel = idx; }
                                }
                                HorizontalLayout {
                                    padding-left: 8px;
                                    spacing: 10px;
                                    Text {
                                        text: n.method;
                                        width: 48px;
                                        color: #9ab8ff;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: n.status == "" ? "..." : n.status;
                                        width: 80px;
                                        color: #8affc0;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: n.url;
                                        color: #e6e6f0;
                                        overflow: elide;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        if root.dev-net-sel >= 0 && root.dev-net-sel < root.dev-net.length : ScrollView {
                            height: 40%;
                            VerticalLayout {
                                padding: 8px;
                                spacing: 4px;
                                alignment: start;
                                Text {
                                    text: "▸ " + root.dev-net[root.dev-net-sel].method + " " + root.dev-net[root.dev-net-sel].url;
                                    color: #ffffff;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: "Status: " + root.dev-net[root.dev-net-sel].status + "    MIME: " + root.dev-net[root.dev-net-sel].mime;
                                    color: #c0c4d8;
                                }
                                Text {
                                    text: "— Request headers —";
                                    color: #8a8a9a;
                                }
                                Text {
                                    text: root.dev-net[root.dev-net-sel].req-headers;
                                    color: #c0c4d8;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: "— Response headers —";
                                    color: #8a8a9a;
                                }
                                Text {
                                    text: root.dev-net[root.dev-net-sel].resp-headers;
                                    color: #c0c4d8;
                                    wrap: word-wrap;
                                }
                                Text {
                                    text: "— Body —";
                                    color: #8a8a9a;
                                }
                                Text {
                                    text: root.dev-net[root.dev-net-sel].body;
                                    color: #c0c4d8;
                                    wrap: word-wrap;
                                }
                            }
                        }
                    }
                }
            }

            // Find bar (M9): barra de busca na página, ancorada no topo-direito. Abre por Ctrl+F ou
            // pelo menu ⋯; o TextInput foca ao aparecer (`init`). Injeção de JS no Rust (setup_find).
            if root.find-open : Rectangle {
                x: parent.width - self.width - 14px;
                y: 14px;
                width: 380px;
                height: 46px;
                background: Theme.bg-elevated;
                border-radius: Theme.radius-panel;
                border-width: 1px;
                border-color: Theme.border;
                drop-shadow-color: #00000070;
                drop-shadow-blur: 24px;
                drop-shadow-offset-y: 8px;
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 8px;
                    spacing: 6px;
                    Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.bg-surface-2;
                        border-radius: Theme.radius-btn;
                        border-width: 1px;
                        border-color: find-input.has-focus ? Theme.accent : Theme.border;
                        find-input := TextInput {
                            x: 10px;
                            width: parent.width - 20px;
                            height: 100%;
                            vertical-alignment: center;
                            color: Theme.text-hi;
                            font-size: 13px;
                            single-line: true;
                            init => { self.focus(); }
                            edited => { root.find-in-page(self.text, true); }
                            accepted => { root.find-in-page(self.text, true); }
                        }
                        if find-input.text == "" : Text {
                            x: 10px;
                            height: 100%;
                            vertical-alignment: center;
                            color: Theme.text-lo;
                            font-size: 13px;
                            text: "Localizar na página";
                        }
                    }
                    Text {
                        text: root.find-count > 0 ? "\{root.find-index}/\{root.find-count}" : (find-input.text == "" ? "" : "0/0");
                        color: Theme.text-mid;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                    IconBtn {
                        width: 28px;
                        height: 28px;
                        glyph: "‹";
                        glyph-size: 20px;
                        hover-bg: Theme.bg-surface;
                        clicked => { root.find-in-page(find-input.text, false); }
                    }
                    IconBtn {
                        width: 28px;
                        height: 28px;
                        glyph: "›";
                        glyph-size: 20px;
                        hover-bg: Theme.bg-surface;
                        clicked => { root.find-in-page(find-input.text, true); }
                    }
                    IconBtn {
                        width: 28px;
                        height: 28px;
                        glyph: "×";
                        glyph-size: 16px;
                        glyph-color: Theme.text-mid;
                        hover-bg: Theme.bg-surface;
                        clicked => {
                            root.find-open = false;
                            root.find-close();
                        }
                    }
                }
            }

            // Menu overflow ⋯ (M9): overlay sobre a área web, ancorado no topo-direito (sob o botão ⋯).
            // Recolhe o que poluía a toolbar. Clicar fora fecha. Zoom/Find entram em T6/T7.
            if root.menu-open : Rectangle {
                width: 100%;
                height: 100%;
                TouchArea {
                    clicked => { root.menu-open = false; }
                }
                Rectangle {
                    x: parent.width - self.width - 8px;
                    y: 8px;
                    width: 244px;
                    background: Theme.bg-elevated;
                    border-radius: Theme.radius-panel;
                    border-width: 1px;
                    border-color: Theme.border;
                    drop-shadow-color: #00000070;
                    drop-shadow-blur: 24px;
                    drop-shadow-offset-y: 10px;
                    // Absorve cliques na área do card (fora dos itens) p/ não fechar o menu.
                    TouchArea { }
                    VerticalLayout {
                        padding: 6px;
                        spacing: 2px;
                        MenuItem {
                            label: "Histórico";
                            clicked => {
                                root.menu-open = false;
                                root.history-open = true;
                                root.toggle-history();
                            }
                        }
                        MenuItem {
                            label: "Buscar na página";
                            hint: "Ctrl+F";
                            clicked => {
                                root.menu-open = false;
                                root.find-open = true;
                            }
                        }
                        MenuItem {
                            label: "Limpar dados";
                            clicked => {
                                root.menu-open = false;
                                root.clear-browsing-data();
                            }
                        }
                        MenuItem {
                            label: "DevTools";
                            clicked => {
                                root.menu-open = false;
                                root.devtools-open = true;
                                root.toggle-devtools();
                            }
                        }
                        // Separador antes da linha de zoom.
                        Rectangle {
                            height: 7px;
                            Rectangle {
                                y: 3px;
                                height: 1px;
                                background: Theme.border;
                            }
                        }
                        // Zoom (M9): − [NN%] + — não fecha o menu (permite ajustar várias vezes).
                        Rectangle {
                            height: 34px;
                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 6px;
                                spacing: 6px;
                                Text {
                                    text: "Zoom";
                                    color: Theme.text-mid;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                IconBtn {
                                    width: 26px;
                                    height: 26px;
                                    glyph: "−";
                                    glyph-size: 18px;
                                    glyph-color: Theme.text-hi;
                                    hover-bg: Theme.bg-surface;
                                    clicked => { root.zoom-out(); }
                                }
                                Text {
                                    width: 50px;
                                    text: "\{root.zoom-percent}%";
                                    color: Theme.text-hi;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                IconBtn {
                                    width: 26px;
                                    height: 26px;
                                    glyph: "+";
                                    glyph-size: 18px;
                                    glyph-color: Theme.text-hi;
                                    hover-bg: Theme.bg-surface;
                                    clicked => { root.zoom-in(); }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
