// Chrome do BasedBrowser. Entra no Rust via re-export inline da macro
// `slint::slint!(export { MainWindow, .. } from "../ui/app.slint")` — SEM build.rs (L-007:
// `include_modules!()` injeta o gerado como fonte do crate → 640 erros nos lints `deny`; a macro
// de crate externo é isenta do clippy). Decodifica eventos a primitivos; a tradução para
// `InputEvent` do Servo mora no Rust (`input.rs`).
//
// M9 (ADR-0012): redesign "dark refinado". Tokens centralizados em `global Theme` (espelham
// `.specs/features/m9-redesign-ui/spec.md` e o mock em `designs/based-browser.pen`). Botões em
// ÍCONE (`IconBtn`), omnibox arredondada com cadeado, abas-pílula, e o menu overflow `⋯` que
// recolhe Histórico/Limpar/DevTools/Zoom/Find. A função (props/callbacks) é a do M2–M7; o M9 só
// muda o VISUAL e ADICIONA affordances (sem regredir).
import { ListView, ScrollView } from "std-widgets.slint";

// Uma aba na barra de abas (M4). O Rust constrói um `VecModel<TabInfo>` a partir do `TabManager`
// (fonte da verdade) e o entrega à propriedade `tabs`. `active` destaca a aba atual. `icon` (M9):
// favicon da página (vazio até o Servo entregar via `notify_favicon_changed`).
export struct TabInfo {
    title: string,
    active: bool,
    icon: image,
}

// Um favorito na barra de favoritos (M4). O Rust constrói um `VecModel<BookmarkInfo>` a partir do
// `AppData` (persistido em ~/.config/basedbrowser/bookmarks.json) e o entrega à propriedade `bookmarks`.
export struct BookmarkInfo {
    title: string,
    url: string,
}

// Uma entrada de histórico (M4) — usada tanto no painel de histórico quanto no autocomplete da barra.
// O Rust filtra/ordena (mais recente primeiro) e entrega via `history` (painel) e `suggestions` (barra).
export struct HistoryItem {
    title: string,
    url: string,
}

// M7 (ADR-0010): painel de devtools. Linha de console (nível + texto) e linha de rede (req+resp,
// headers/payload já achatados em string pelo Rust — Slint não modela bem listas de tuplas aninhadas).
export struct DevConsoleLine {
    level: string,
    text: string,
}

export struct DevNetRow {
    method: string,
    url: string,
    name: string,
    status: string,
    // M10: classe do status p/ colorir (2/3/4/5 = centena; 1 = outro; 0 = pendente).
    status-class: int,
    // M10: rótulo do tipo do recurso (xhr/doc/js/css/img/fonte/outro — do cause.type do RDP).
    kind-label: string,
    mime: string,
    // M10: tamanho e tempo humanizados ("1.2 kB", "120 ms"); vazios se ignotos.
    size: string,
    time: string,
    req-headers: string,
    // M10: payload da request (getRequestPostData), JSON indentado quando aplicável.
    req-body: string,
    resp-headers: string,
    body: string,
}

// M9: tokens do tema "dark refinado" (fonte da verdade compartilhada com o mock do Pencil).
global Theme {
    out property <color> bg-base: #0f0f14;
    out property <color> bg-surface: #15151b;
    out property <color> bg-surface-2: #1e1e26;
    out property <color> bg-elevated: #2a2a3a;
    out property <color> accent: #6c5ce7;
    out property <color> accent-soft: #6c5ce733;
    out property <color> text-hi: #f0f0f5;
    out property <color> text-mid: #9a9aa6;
    out property <color> text-lo: #6a6a7a;
    out property <color> border: #2a2a38;
    out property <color> danger: #ff6b6b;
    out property <color> ok: #5dd1a0;
    out property <length> radius-pill: 8px;
    out property <length> radius-btn: 6px;
    out property <length> radius-panel: 12px;
}

// M9: botão em ícone (glifo de texto), com estados enabled/hover/disabled. Reusado em toda a barra
// (nav ‹ › ⟳, ★, ⋯, +, × das pílulas, controles de zoom/find). O root NÃO fixa height: estica na
// linha (HorizontalLayout) e o box visível (size×size) é centrado em y → o ícone fica VERTICALMENTE
// centrado (os layouts do Slint top-alinham filhos de tamanho fixo).
component IconBtn inherits Rectangle {
    in property <string> glyph;
    in property <bool> enabled: true;
    in property <length> size: 34px;
    in property <length> glyph-size: 18px;
    in property <color> glyph-color: Theme.text-hi;
    in property <color> hover-bg: Theme.bg-elevated;
    callback clicked();
    width: root.size;
    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    Rectangle {
        width: root.size;
        height: root.size;
        y: (parent.height - self.height) / 2;
        border-radius: Theme.radius-btn;
        background: root.enabled && touch.has-hover ? root.hover-bg : transparent;
        animate background { duration: 90ms; }
        Text {
            width: 100%;
            height: 100%;
            horizontal-alignment: center;
            vertical-alignment: center;
            text: root.glyph;
            font-size: root.glyph-size;
            color: root.enabled ? root.glyph-color : Theme.text-lo;
        }
    }
}

// M9: cadeado da omnibox desenhado (monocromático, respeita o tema) — fechado/ok p/ https, neutro
// p/ http. O root estica na linha; o glifo 14x14 (arco + corpo) é centrado em y.
component LockIcon inherits Rectangle {
    in property <bool> secure;
    width: 14px;
    Rectangle {
        width: 14px;
        height: 14px;
        y: (parent.height - self.height) / 2;
        Rectangle {
            x: 3px;
            y: 0;
            width: 8px;
            height: 9px;
            border-radius: 4px;
            border-width: 1.5px;
            border-color: root.secure ? Theme.ok : Theme.text-mid;
            background: transparent;
        }
        Rectangle {
            x: 1.5px;
            y: 5px;
            width: 11px;
            height: 9px;
            border-radius: 2px;
            background: root.secure ? Theme.ok : Theme.text-mid;
        }
    }
}

// M9: item do menu overflow `⋯` — rótulo + dica de atalho à direita; hover em accent-soft.
component MenuItem inherits Rectangle {
    in property <string> label;
    in property <string> hint;
    callback clicked();
    height: 34px;
    border-radius: Theme.radius-btn;
    background: touch.has-hover ? Theme.accent-soft : transparent;
    animate background { duration: 90ms; }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        padding-left: 12px;
        padding-right: 12px;
        spacing: 12px;
        Text {
            text: root.label;
            font-size: 13px;
            color: Theme.text-hi;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
        Text {
            text: root.hint;
            font-size: 12px;
            color: Theme.text-lo;
            vertical-alignment: center;
        }
    }
}

// M9: botão de texto temático (painéis de histórico/devtools). `active` realça (aba selecionada).
component TextBtn inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked();
    height: 30px;
    horizontal-stretch: 0;
    border-radius: Theme.radius-btn;
    background: root.active ? Theme.accent-soft : (touch.has-hover ? Theme.bg-elevated : Theme.bg-surface-2);
    animate background { duration: 90ms; }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        padding-left: 14px;
        padding-right: 14px;
        Text {
            text: root.label;
            color: root.active ? Theme.accent : Theme.text-hi;
            font-size: 13px;
            vertical-alignment: center;
            horizontal-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

// M9: campo de texto temático (busca de histórico, REPL do devtools) — TextInput sem o chrome do
// std-widget + placeholder + borda que acende no foco. `text` é alias bidirecional p/ o consumidor
// poder limpar (ex.: após avaliar no devtools).
component SearchField inherits Rectangle {
    in property <string> placeholder;
    in property <bool> mono: false; // M10: fonte monospace (REPL de eval do devtools)
    in-out property <string> text <=> input.text;
    callback edited(string);
    callback accepted(string);
    height: 34px;
    background: Theme.bg-surface-2;
    border-radius: Theme.radius-btn;
    border-width: 1px;
    border-color: input.has-focus ? Theme.accent : Theme.border;
    animate border-color { duration: 120ms; }
    input := TextInput {
        x: 12px;
        width: parent.width - 24px;
        height: 100%;
        vertical-alignment: center;
        color: Theme.text-hi;
        font-size: 13px;
        font-family: root.mono ? "monospace" : "";
        single-line: true;
        edited => { root.edited(self.text); }
        accepted => { root.accepted(self.text); }
    }
    if input.text == "" : Text {
        x: 12px;
        height: 100%;
        vertical-alignment: center;
        color: Theme.text-lo;
        font-size: 13px;
        text: root.placeholder;
    }
}

// M10: botão do toolbar do DevTools — ÍCONE compacto que REVELA o texto no hover (e mostra o label
// quando é a aba `active`). Mantém a barra estreita (cabe no dock à direita) com descoberta por hover
// (estilo Chrome). O root estica na linha; o conteúdo (ícone + label) é centrado.
component DevToolBtn inherits Rectangle {
    in property <string> glyph;
    in property <string> tip;
    in property <bool> active: false;
    callback clicked();
    height: 28px;
    border-radius: Theme.radius-btn;
    background: root.active ? Theme.accent-soft : (touch.has-hover ? Theme.bg-elevated : transparent);
    animate background { duration: 90ms; }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        padding-left: 7px;
        padding-right: 7px;
        spacing: 5px;
        alignment: center;
        Text {
            text: root.glyph;
            font-size: 15px;
            color: root.active ? Theme.accent : Theme.text-mid;
            vertical-alignment: center;
        }
        // A aba ATIVA mostra o label inline (persistente); os demais mostram tooltip FLUTUANTE no hover.
        if root.active : Text {
            text: root.tip;
            font-size: 12px;
            color: Theme.accent;
            vertical-alignment: center;
        }
    }
    // Tooltip flutuante (M10): Rectangle simples ACIMA do botão. NÃO ocupa espaço no layout (x/y
    // próprios, fora do fluxo) e NÃO captura ponteiro (sem TouchArea) → não pisca ao mover o mouse
    // (o PopupWindow piscava por capturar o ponteiro). A aba ativa não usa (já tem label inline).
    if touch.has-hover && !root.active : Rectangle {
        x: 0;
        y: -27px;
        width: tiplabel.preferred-width + 16px;
        height: 22px;
        background: Theme.bg-elevated;
        border-radius: 5px;
        border-width: 1px;
        border-color: Theme.border;
        drop-shadow-color: #000000a0;
        drop-shadow-blur: 12px;
        drop-shadow-offset-y: 2px;
        tiplabel := Text {
            x: 8px;
            height: 100%;
            vertical-alignment: center;
            text: root.tip;
            color: Theme.text-hi;
            font-size: 11px;
        }
    }
}

// M10: chip de filtro por tipo de recurso (painel de rede) — pílula compacta; ativa em accent.
component Chip inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked();
    height: 22px;
    border-radius: 11px;
    background: root.active ? Theme.accent-soft : (touch.has-hover ? Theme.bg-elevated : Theme.bg-surface-2);
    border-width: 1px;
    border-color: root.active ? Theme.accent : Theme.border;
    animate background { duration: 90ms; }
    touch := TouchArea {
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
    HorizontalLayout {
        padding-left: 9px;
        padding-right: 9px;
        Text {
            text: root.label;
            font-size: 11px;
            color: root.active ? Theme.accent : Theme.text-mid;
            vertical-alignment: center;
        }
    }
}

// Chrome do M2/M4/M7 repaginado no M9: barra de abas + toolbar (omnibox) + favoritos + área web.
// O `.slint` apenas DECODIFICA cada evento para primitivos e chama um callback; a tradução
// primitivo -> `InputEvent` do Servo mora no Rust (`input.rs`). Coordenadas: declarar os params como
// `physical-length` faz o Slint converter logical -> físico pelo scale factor, e como a Image usa
// `image-fit: fill` sobre um contexto do Servo do MESMO tamanho da área web, o mapeamento é
// identidade (physical-px == device-px do Servo). Sem matemática de letterbox.
export component MainWindow inherits Window {
    // Dirigidas pelo Rust (pipeline de frame + WebViewDelegate).
    in property <image> frame;
    in property <string> page-url;
    in property <bool> loading;
    in property <bool> can-go-back;
    in property <bool> can-go-forward;
    in property <string> window-title: "BasedBrowser";
    // M9: URL atual é https (cadeado fechado) — derivado no Rust (sync_chrome).
    in property <bool> page-secure: false;
    // M9: zoom da aba ativa em % (inteiro) — mostrado no menu ⋯.
    in property <int> zoom-percent: 100;
    // M4: lista de abas (derivada do TabManager no Rust).
    in property <[TabInfo]> tabs;
    // M4: lista de favoritos (derivada do AppData no Rust).
    in property <[BookmarkInfo]> bookmarks;
    // M4: histórico filtrado p/ o painel + sugestões de autocomplete da barra (ambos do Rust).
    in property <[HistoryItem]> history;
    in property <[HistoryItem]> suggestions;
    // Visibilidade do painel de histórico (alternada pelo menu ⋯; o Rust também pode fechá-lo).
    in-out property <bool> history-open: false;
    // M9: menu overflow ⋯ (recolhe Histórico/Limpar/DevTools/Zoom/Find).
    in-out property <bool> menu-open: false;
    // M9: find-in-page (Ctrl+F / menu ⋯). count=total de ocorrências, index=atual (1-based).
    in-out property <bool> find-open: false;
    in property <int> find-count: 0;
    in property <int> find-index: 0;
    // M9: menu de contexto (right-click na área web). Posição em coords LÓGICAS (mouse-x/y do Slint).
    in-out property <bool> ctx-open: false;
    property <length> ctx-x;
    property <length> ctx-y;
    // M7 (ADR-0010): painel de devtools (console/eval + rede). Models e status vêm do Rust.
    in property <[DevConsoleLine]> dev-console;
    in property <[DevNetRow]> dev-net;
    in property <string> dev-status: "";
    in-out property <bool> devtools-open: false;
    in-out property <int> dev-tab: 0; // 0 = console, 1 = rede
    in-out property <int> dev-net-sel: -1; // linha de rede selecionada (detalhe)
    in-out property <int> dev-net-detail-tab: 1; // 0 = Request, 1 = Response (no detalhe)
    // M10 (ADR-0014): porta do servidor RDP (0 = desligado) p/ a afford. "Debugger ↗" (step-debug Firefox).
    in property <int> dev-rdp-port: 0;
    in-out property <bool> debug-info-open: false;
    // M10: dock do DevTools (split screen). devtools-size = ALTURA (base) ou LARGURA (direita) do dock.
    in-out property <length> devtools-size: 300px;
    in-out property <bool> dock-right: false; // false = base (split horizontal), true = direita (vertical)

    // Chrome -> Rust.
    callback load-url(string);
    callback go-back();
    callback go-forward();
    callback reload();
    // M4: ciclo de vida das abas (índice 0-based na lista `tabs`).
    callback new-tab();
    callback select-tab(int);
    callback close-tab(int);
    // M4: favoritos (★ adiciona a página atual; open/remove por índice na lista `bookmarks`).
    callback add-bookmark();
    callback open-bookmark(int);
    callback remove-bookmark(int);
    // M4: histórico. toggle-history abre/atualiza o painel; search-history filtra; open-history abre
    // a entrada `history[i]`. url-edited alimenta o autocomplete; open-suggestion abre `suggestions[i]`.
    callback toggle-history();
    callback search-history(string);
    callback open-history(int);
    callback url-edited(string);
    callback open-suggestion(int);
    // M6: limpar dados de navegação (cookies + Web Storage do Servo + nosso histórico; preserva
    // favoritos e a sessão de abas).
    callback clear-browsing-data();
    // M7: devtools. toggle-devtools (re)abre o painel (Rust atualiza os models); dev-eval roda JS na
    // aba ativa; clear-devtools limpa os buffers de console/rede.
    callback toggle-devtools();
    callback dev-eval(string);
    callback clear-devtools();
    // M10: filtro do painel de rede (URL/método/status/nome).
    callback search-devtools(string);
    // M10: filtro por TIPO de recurso na rede (chips; índice de net_kind no Rust; 0 = todos).
    in-out property <int> dev-net-kind: 0;
    callback filter-net-kind(int);
    // M10 (T5): persiste tamanho/orientação do dock (chamado no fim do arrasto do divisor e no toggle).
    callback persist-dock();
    // M9: zoom de página (Ctrl +/−/0 e o menu ⋯).
    callback zoom-in();
    callback zoom-out();
    callback zoom-reset();
    // M9: find-in-page. find-in-page(query, forward) busca/navega; find-close limpa os destaques.
    callback find-in-page(string, bool);
    callback find-close();
    // M9: foco da omnibox (Ctrl+L) — o Rust invoca; tratado internamente no Slint (handler abaixo).
    callback focus-url-bar();
    // Input -> Rust. pointer: (x, y, kind, button); kind 0=down 1=up 2=move; button 0=left
    // 1=right 2=middle 3=outro. scroll: (x, y, delta-x, delta-y). key: (text, pressed, ctrl,
    // shift, alt, meta, repeat). web-resized: novo tamanho FÍSICO da área web.
    callback forward-pointer(physical-length, physical-length, int, int);
    callback forward-scroll(physical-length, physical-length, length, length);
    callback forward-key(string, bool, bool, bool, bool, bool, bool);
    callback web-resized(physical-length, physical-length);

    title: root.window-title;
    preferred-width: 1024px;
    preferred-height: 768px;
    background: Theme.bg-base;

    // M9: Ctrl+L (Rust invoca `focus-url-bar`) → foca a omnibox.
    focus-url-bar => {
        omni-input.focus();
    }

    VerticalLayout {
        padding: 0;
        spacing: 0;

        // Barra de abas (M4/M9): pílulas com favicon + título (elide) + × no hover; aba ativa
        // elevada (bg-elevated) com contorno de accent. Botão + discreto à direita.
        Rectangle {
            background: Theme.bg-surface;
            height: 42px;
            HorizontalLayout {
                padding: 8px;
                padding-bottom: 0;
                spacing: 6px;
                for tab[idx] in root.tabs : Rectangle {
                    width: 188px;
                    height: 34px;
                    border-radius: Theme.radius-pill;
                    background: tab.active ? Theme.bg-elevated : transparent;
                    border-width: 1px;
                    border-color: tab.active ? Theme.accent : transparent;
                    select := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.select-tab(idx); }
                    }
                    HorizontalLayout {
                        padding-left: 10px;
                        padding-right: 4px;
                        spacing: 8px;
                        // Favicon (M9): dot placeholder neutro + Image por cima (imagem vazia não
                        // renderiza → o dot aparece; quando o Servo entrega o favicon, ele cobre o dot).
                        Rectangle {
                            width: 15px;
                            Rectangle {
                                width: 15px;
                                height: 15px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 4px;
                                background: tab.active ? Theme.accent : Theme.text-lo;
                                Image {
                                    width: 100%;
                                    height: 100%;
                                    image-fit: contain;
                                    source: tab.icon;
                                }
                            }
                        }
                        Text {
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                            color: tab.active ? Theme.text-hi : Theme.text-mid;
                            overflow: elide;
                            font-size: 13px;
                            text: tab.title == "" ? "Nova aba" : tab.title;
                        }
                        IconBtn {
                            size: 22px;
                            glyph: "×";
                            glyph-size: 16px;
                            glyph-color: Theme.text-mid;
                            hover-bg: #4a4a5e;
                            clicked => { root.close-tab(idx); }
                        }
                    }
                }
                IconBtn {
                    size: 30px;
                    glyph: "+";
                    glyph-size: 18px;
                    glyph-color: Theme.text-mid;
                    clicked => { root.new-tab(); }
                }
                // Empurra as abas para a esquerda (não esticam para preencher a barra).
                Rectangle { horizontal-stretch: 1; }
            }
        }

        // Toolbar (M9): nav em ícone ‹ › ⟳ + omnibox arredondada (cadeado + URL + ★) + menu ⋯.
        Rectangle {
            background: Theme.bg-surface;
            height: 52px;
            HorizontalLayout {
                padding: 8px;
                spacing: 6px;
                IconBtn {
                    glyph: "‹";
                    glyph-size: 24px;
                    enabled: root.can-go-back;
                    clicked => { root.go-back(); }
                }
                IconBtn {
                    glyph: "›";
                    glyph-size: 24px;
                    enabled: root.can-go-forward;
                    clicked => { root.go-forward(); }
                }
                IconBtn {
                    glyph: "⟳";
                    glyph-size: 19px;
                    clicked => { root.reload(); }
                }
                // Omnibox: campo arredondado com cadeado, TextInput (sem chrome do std) e ★.
                Rectangle {
                    horizontal-stretch: 1;
                    background: Theme.bg-surface-2;
                    border-radius: Theme.radius-pill;
                    border-width: 1px;
                    border-color: omni-input.has-focus ? Theme.accent : Theme.border;
                    animate border-color { duration: 120ms; }
                    HorizontalLayout {
                        padding-left: 12px;
                        padding-right: 4px;
                        spacing: 8px;
                        LockIcon {
                            secure: root.page-secure;
                        }
                        // Wrapper p/ sobrepor o placeholder quando vazio (TextInput não tem placeholder).
                        Rectangle {
                            horizontal-stretch: 1;
                            omni-input := TextInput {
                                width: 100%;
                                height: 100%;
                                vertical-alignment: center;
                                color: Theme.text-hi;
                                font-size: 13px;
                                single-line: true;
                                // edited → autocomplete; accepted (Enter) → carrega e limpa as sugestões.
                                text: root.page-url;
                                accepted => { root.load-url(self.text); root.url-edited(""); }
                                edited => { root.url-edited(self.text); }
                            }
                            if omni-input.text == "" : Text {
                                x: 0;
                                height: 100%;
                                vertical-alignment: center;
                                color: Theme.text-lo;
                                font-size: 13px;
                                text: "Pesquisar ou digitar uma URL";
                            }
                        }
                        IconBtn {
                            size: 28px;
                            glyph: "★";
                            glyph-size: 15px;
                            glyph-color: Theme.accent;
                            hover-bg: Theme.bg-elevated;
                            clicked => { root.add-bookmark(); }
                        }
                    }
                }
                IconBtn {
                    glyph: "⋯";
                    glyph-size: 22px;
                    clicked => { root.menu-open = !root.menu-open; }
                }
            }
        }

        // Indicador de loading (M9): barra fina de accent sob a toolbar (substitui o texto "carregando").
        Rectangle {
            height: 2px;
            background: root.loading ? Theme.accent : transparent;
            animate background { duration: 120ms; }
        }

        // Barra de favoritos (M4/M9): aparece só se há favoritos. Cada pílula abre na aba ativa; o ×
        // remove. Mesmo sistema visual das abas.
        if root.bookmarks.length > 0 : Rectangle {
            background: Theme.bg-surface;
            height: 34px;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                padding-bottom: 4px;
                spacing: 4px;
                for bm[idx] in root.bookmarks : Rectangle {
                    height: 26px;
                    min-width: 60px;
                    max-width: 200px;
                    border-radius: Theme.radius-btn;
                    background: bmtouch.has-hover ? Theme.bg-elevated : transparent;
                    bmtouch := TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.open-bookmark(idx); }
                    }
                    HorizontalLayout {
                        padding-left: 8px;
                        padding-right: 3px;
                        spacing: 6px;
                        Rectangle {
                            width: 12px;
                            Rectangle {
                                width: 12px;
                                height: 12px;
                                y: (parent.height - self.height) / 2;
                                border-radius: 3px;
                                background: Theme.text-mid;
                            }
                        }
                        Text {
                            horizontal-stretch: 1;
                            vertical-alignment: center;
                            overflow: elide;
                            color: Theme.text-mid;
                            font-size: 12px;
                            text: bm.title == "" ? bm.url : bm.title;
                        }
                        IconBtn {
                            size: 18px;
                            glyph: "×";
                            glyph-size: 13px;
                            glyph-color: Theme.text-lo;
                            hover-bg: #4a4a5e;
                            clicked => { root.remove-bookmark(idx); }
                        }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
            }
        }

        // Area web: a Image exibe o frame do Servo; a TouchArea captura pointer/scroll e o
        // FocusScope captura teclado. `web-resized` dispara quando o layout muda o tamanho.
        // Área de conteúdo (M10): contém a PÁGINA (`web`) + o dock do DevTools + o divisor, posicionados
        // MANUALMENTE p/ o dock encaixar na BASE ou na DIREITA (toggle `dock-right`) e a página ENCOLHER.
        // `web` mantém `changed width/height => web-resized` → encolher dispara o reflow do Servo. As
        // overlays (find/menu/ctx/histórico) são filhas de `web` → seguem o tamanho dela.
        content := Rectangle {
            vertical-stretch: 1;
            background: Theme.bg-base;
            web := Rectangle {
                x: 0;
                y: 0;
                width: root.devtools-open && root.dock-right ? content.width - root.devtools-size - 6px : content.width;
                height: root.devtools-open && !root.dock-right ? content.height - root.devtools-size - 6px : content.height;
                background: Theme.bg-surface-2;
                changed width => { root.web-resized(self.width, self.height); }
                changed height => { root.web-resized(self.width, self.height); }

            Image {
                width: 100%;
                height: 100%;
                image-fit: fill;
                source: root.frame;
            }
            fs := FocusScope {
                width: 100%;
                height: 100%;
                key-pressed(e) => {
                    root.forward-key(e.text, true, e.modifiers.control, e.modifiers.shift,
                        e.modifiers.alt, e.modifiers.meta, e.repeat);
                    accept
                }
                key-released(e) => {
                    root.forward-key(e.text, false, e.modifiers.control, e.modifiers.shift,
                        e.modifiers.alt, e.modifiers.meta, false);
                    accept
                }
                TouchArea {
                    width: 100%;
                    height: 100%;
                    pointer-event(e) => {
                        // M9: right-click abre o menu de contexto do chrome (não repassa à página).
                        if (e.button == PointerEventButton.right) {
                            if (e.kind == PointerEventKind.down) {
                                root.ctx-x = self.mouse-x;
                                root.ctx-y = self.mouse-y;
                                root.ctx-open = true;
                                root.menu-open = false;
                            }
                        } else {
                            root.forward-pointer(
                                self.mouse-x,
                                self.mouse-y,
                                e.kind == PointerEventKind.down ? 0
                                    : e.kind == PointerEventKind.up ? 1 : 2,
                                e.button == PointerEventButton.left ? 0
                                    : e.button == PointerEventButton.right ? 1
                                    : e.button == PointerEventButton.middle ? 2 : 3);
                        }
                        fs.focus();
                    }
                    scroll-event(e) => {
                        root.forward-scroll(self.mouse-x, self.mouse-y, e.delta-x, e.delta-y);
                        accept
                    }
                }
            }

            // Autocomplete (M4): sugestões de histórico ancoradas no topo da área web, enquanto se
            // digita na barra de URL. Some quando não há sugestões (Rust limpa no Enter / texto vazio).
            if root.suggestions.length > 0 : Rectangle {
                y: 0;
                x: 0;
                width: 100%;
                height: min(root.suggestions.length * 32px, 6 * 32px);
                background: Theme.bg-elevated;
                border-color: Theme.border;
                border-width: 1px;
                VerticalLayout {
                    for s[idx] in root.suggestions : Rectangle {
                        height: 32px;
                        background: stouch.has-hover ? Theme.accent-soft : transparent;
                        stouch := TouchArea {
                            mouse-cursor: pointer;
                            clicked => { root.open-suggestion(idx); }
                        }
                        HorizontalLayout {
                            padding-left: 12px;
                            Text {
                                vertical-alignment: center;
                                color: Theme.text-hi;
                                overflow: elide;
                                text: s.url;
                            }
                        }
                    }
                }
            }

            // Painel de histórico (M4): overlay sobre a área web com busca + lista (revisitar).
            if root.history-open : Rectangle {
                width: 100%;
                height: 100%;
                background: Theme.bg-base;
                VerticalLayout {
                    padding: 16px;
                    spacing: 12px;
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Histórico";
                            color: Theme.text-hi;
                            font-size: 18px;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                        TextBtn {
                            label: "Fechar";
                            clicked => { root.history-open = false; }
                        }
                    }
                    SearchField {
                        placeholder: "Buscar no histórico…";
                        edited(t) => { root.search-history(t); }
                    }
                    ListView {
                        for h[idx] in root.history : Rectangle {
                            height: 34px;
                            border-radius: Theme.radius-btn;
                            background: htouch.has-hover ? Theme.bg-elevated : transparent;
                            htouch := TouchArea {
                                mouse-cursor: pointer;
                                clicked => { root.open-history(idx); }
                            }
                            HorizontalLayout {
                                padding-left: 10px;
                                spacing: 10px;
                                Text {
                                    width: 45%;
                                    vertical-alignment: center;
                                    color: Theme.text-hi;
                                    overflow: elide;
                                    text: h.title == "" ? h.url : h.title;
                                }
                                Text {
                                    vertical-alignment: center;
                                    color: Theme.text-mid;
                                    overflow: elide;
                                    text: h.url;
                                }
                            }
                        }
                    }
                }
            }

            // Painel de DevTools (M10): MOVIDO p/ fora de `web` — virou um DOCK (split) em `content`,
            // depois de `web` (ver abaixo). Dentro de `web` ficam só as overlays da página.

            // Find bar (M9): barra de busca na página, ancorada no topo-direito. Abre por Ctrl+F ou
            // pelo menu ⋯; o TextInput foca ao aparecer (`init`). Injeção de JS no Rust (setup_find).
            if root.find-open : Rectangle {
                x: parent.width - self.width - 14px;
                y: 14px;
                width: 380px;
                height: 46px;
                background: Theme.bg-elevated;
                border-radius: Theme.radius-panel;
                border-width: 1px;
                border-color: Theme.border;
                drop-shadow-color: #00000070;
                drop-shadow-blur: 24px;
                drop-shadow-offset-y: 8px;
                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 8px;
                    spacing: 6px;
                    Rectangle {
                        horizontal-stretch: 1;
                        background: Theme.bg-surface-2;
                        border-radius: Theme.radius-btn;
                        border-width: 1px;
                        border-color: find-input.has-focus ? Theme.accent : Theme.border;
                        find-input := TextInput {
                            x: 10px;
                            width: parent.width - 20px;
                            height: 100%;
                            vertical-alignment: center;
                            color: Theme.text-hi;
                            font-size: 13px;
                            single-line: true;
                            init => { self.focus(); }
                            edited => { root.find-in-page(self.text, true); }
                            accepted => { root.find-in-page(self.text, true); }
                        }
                        if find-input.text == "" : Text {
                            x: 10px;
                            height: 100%;
                            vertical-alignment: center;
                            color: Theme.text-lo;
                            font-size: 13px;
                            text: "Localizar na página";
                        }
                    }
                    Text {
                        text: root.find-count > 0 ? "\{root.find-index}/\{root.find-count}" : (find-input.text == "" ? "" : "0/0");
                        color: Theme.text-mid;
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                    IconBtn {
                        size: 28px;
                        glyph: "‹";
                        glyph-size: 20px;
                        hover-bg: Theme.bg-surface;
                        clicked => { root.find-in-page(find-input.text, false); }
                    }
                    IconBtn {
                        size: 28px;
                        glyph: "›";
                        glyph-size: 20px;
                        hover-bg: Theme.bg-surface;
                        clicked => { root.find-in-page(find-input.text, true); }
                    }
                    IconBtn {
                        size: 28px;
                        glyph: "×";
                        glyph-size: 16px;
                        glyph-color: Theme.text-mid;
                        hover-bg: Theme.bg-surface;
                        clicked => {
                            root.find-open = false;
                            root.find-close();
                        }
                    }
                }
            }

            // Menu de contexto (M9): right-click na área web. Itens reusam os callbacks de navegação;
            // clicar fora fecha. Posicionado no ponto do clique (clampeado p/ caber na área).
            if root.ctx-open : Rectangle {
                width: 100%;
                height: 100%;
                TouchArea {
                    clicked => { root.ctx-open = false; }
                }
                Rectangle {
                    x: min(root.ctx-x, parent.width - self.width - 8px);
                    y: min(root.ctx-y, parent.height - self.height - 8px);
                    width: 204px;
                    background: Theme.bg-elevated;
                    border-radius: Theme.radius-panel;
                    border-width: 1px;
                    border-color: Theme.border;
                    drop-shadow-color: #00000070;
                    drop-shadow-blur: 24px;
                    drop-shadow-offset-y: 10px;
                    TouchArea { }
                    VerticalLayout {
                        padding: 6px;
                        spacing: 2px;
                        MenuItem {
                            label: "Voltar";
                            clicked => {
                                root.ctx-open = false;
                                root.go-back();
                            }
                        }
                        MenuItem {
                            label: "Avançar";
                            clicked => {
                                root.ctx-open = false;
                                root.go-forward();
                            }
                        }
                        MenuItem {
                            label: "Recarregar";
                            clicked => {
                                root.ctx-open = false;
                                root.reload();
                            }
                        }
                        Rectangle {
                            height: 7px;
                            Rectangle {
                                y: 3px;
                                height: 1px;
                                background: Theme.border;
                            }
                        }
                        MenuItem {
                            label: "Inspecionar";
                            clicked => {
                                root.ctx-open = false;
                                root.devtools-open = true;
                                root.toggle-devtools();
                            }
                        }
                    }
                }
            }

            // Menu overflow ⋯ (M9): overlay sobre a área web, ancorado no topo-direito (sob o botão ⋯).
            // Recolhe o que poluía a toolbar. Clicar fora fecha. Zoom/Find entram em T6/T7.
            if root.menu-open : Rectangle {
                width: 100%;
                height: 100%;
                TouchArea {
                    clicked => { root.menu-open = false; }
                }
                Rectangle {
                    x: parent.width - self.width - 8px;
                    y: 8px;
                    width: 244px;
                    background: Theme.bg-elevated;
                    border-radius: Theme.radius-panel;
                    border-width: 1px;
                    border-color: Theme.border;
                    drop-shadow-color: #00000070;
                    drop-shadow-blur: 24px;
                    drop-shadow-offset-y: 10px;
                    // Absorve cliques na área do card (fora dos itens) p/ não fechar o menu.
                    TouchArea { }
                    VerticalLayout {
                        padding: 6px;
                        spacing: 2px;
                        MenuItem {
                            label: "Histórico";
                            clicked => {
                                root.menu-open = false;
                                root.history-open = true;
                                root.toggle-history();
                            }
                        }
                        MenuItem {
                            label: "Buscar na página";
                            hint: "Ctrl+F";
                            clicked => {
                                root.menu-open = false;
                                root.find-open = true;
                            }
                        }
                        MenuItem {
                            label: "Limpar dados";
                            clicked => {
                                root.menu-open = false;
                                root.clear-browsing-data();
                            }
                        }
                        MenuItem {
                            label: "DevTools";
                            clicked => {
                                root.menu-open = false;
                                root.devtools-open = true;
                                root.toggle-devtools();
                            }
                        }
                        // Separador antes da linha de zoom.
                        Rectangle {
                            height: 7px;
                            Rectangle {
                                y: 3px;
                                height: 1px;
                                background: Theme.border;
                            }
                        }
                        // Zoom (M9): − [NN%] + — não fecha o menu (permite ajustar várias vezes).
                        Rectangle {
                            height: 34px;
                            HorizontalLayout {
                                padding-left: 12px;
                                padding-right: 6px;
                                spacing: 6px;
                                Text {
                                    text: "Zoom";
                                    color: Theme.text-mid;
                                    font-size: 13px;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                                IconBtn {
                                    size: 26px;
                                    glyph: "−";
                                    glyph-size: 18px;
                                    glyph-color: Theme.text-hi;
                                    hover-bg: Theme.bg-surface;
                                    clicked => { root.zoom-out(); }
                                }
                                Text {
                                    width: 50px;
                                    text: "\{root.zoom-percent}%";
                                    color: Theme.text-hi;
                                    font-size: 12px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                }
                                IconBtn {
                                    size: 26px;
                                    glyph: "+";
                                    glyph-size: 18px;
                                    glyph-color: Theme.text-hi;
                                    hover-bg: Theme.bg-surface;
                                    clicked => { root.zoom-in(); }
                                }
                            }
                        }
                    }
                }
            }
        }
            // Divisor arrastável (M10): acumulador `grab` no press + `devtools-size += grab - mouse` por
            // `moved` → o divisor segue o ponteiro sem feedback (1 frame de lag), sem depender de absolute-position.
            if root.devtools-open : Rectangle {
                x: root.dock-right ? content.width - root.devtools-size - 6px : 0;
                y: root.dock-right ? 0 : content.height - root.devtools-size - 6px;
                width: root.dock-right ? 6px : content.width;
                height: root.dock-right ? content.height : 6px;
                background: dragta.has-hover || dragta.pressed ? Theme.accent : Theme.border;
                animate background { duration: 90ms; }
                dragta := TouchArea {
                    mouse-cursor: root.dock-right ? ew-resize : ns-resize;
                    property <length> grab;
                    pointer-event(e) => {
                        if (e.kind == PointerEventKind.down) {
                            self.grab = root.dock-right ? self.mouse-x : self.mouse-y;
                        } else if (e.kind == PointerEventKind.up) {
                            root.persist-dock();
                        }
                    }
                    moved => {
                        if (root.dock-right) {
                            root.devtools-size = clamp(root.devtools-size + (self.grab - self.mouse-x), 360px, content.width - 360px);
                        } else {
                            root.devtools-size = clamp(root.devtools-size + (self.grab - self.mouse-y), 160px, content.height - 160px);
                        }
                    }
                }
            }
            // Dock do DevTools (M10): painel posicionado na BASE (full-width embaixo) ou na DIREITA
            // (full-height à direita). Conteúdo = M7 (console/eval + rede), reusando models/callbacks.
            if root.devtools-open : Rectangle {
                x: root.dock-right ? content.width - root.devtools-size : 0;
                y: root.dock-right ? 0 : content.height - root.devtools-size;
                width: root.dock-right ? root.devtools-size : content.width;
                height: root.dock-right ? content.height : root.devtools-size;
                background: Theme.bg-base;
                border-color: Theme.border;
                border-width: 1px;
                VerticalLayout {
                    padding: 10px;
                    spacing: 8px;
                    // Toolbar do DevTools (M10): barra de ÍCONES compactos que revelam o texto no hover
                    // (e mostram o label quando é a aba ativa) — cabe no dock estreito (à direita).
                    HorizontalLayout {
                        spacing: 4px;
                        DevToolBtn {
                            glyph: "❯";
                            tip: "Console";
                            active: root.dev-tab == 0;
                            clicked => { root.dev-tab = 0; }
                        }
                        DevToolBtn {
                            glyph: "⇅";
                            tip: "Rede";
                            active: root.dev-tab == 1;
                            clicked => { root.dev-tab = 1; }
                        }
                        Text {
                            text: root.dev-status;
                            color: Theme.text-lo;
                            font-size: 11px;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                            overflow: elide;
                        }
                        DevToolBtn {
                            glyph: "⌦";
                            tip: "Limpar";
                            clicked => { root.clear-devtools(); }
                        }
                        DevToolBtn {
                            glyph: "⊟";
                            tip: root.dock-right ? "Dock na base" : "Dock à direita";
                            clicked => {
                                root.dock-right = !root.dock-right;
                                root.devtools-size = root.dock-right ? content.width / 2 : content.height / 2;
                                root.persist-dock();
                            }
                        }
                        DevToolBtn {
                            glyph: "↗";
                            tip: "Debugger (Firefox)";
                            active: root.debug-info-open;
                            clicked => { root.debug-info-open = !root.debug-info-open; }
                        }
                        DevToolBtn {
                            glyph: "✕";
                            tip: "Fechar";
                            clicked => { root.devtools-open = false; }
                        }
                    }

                    // M10 (ADR-0014 / caminho A): afford. de step-debug via Firefox. O painel in-app é
                    // OBSERVACIONAL (console/rede/eval); breakpoints/pause/step vivem no MOTOR (mozjs) →
                    // inalcançáveis pelo embedder. A forma completa é o Firefox no NOSSO socket RDP.
                    if root.debug-info-open : Rectangle {
                        background: Theme.bg-surface-2;
                        border-radius: Theme.radius-btn;
                        border-width: 1px;
                        border-color: Theme.accent-soft;
                        VerticalLayout {
                            padding: 8px;
                            spacing: 4px;
                            Text {
                                text: "Step-debugger (breakpoints/pause/step) via Firefox DevTools:";
                                color: Theme.text-hi;
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                            if root.dev-rdp-port > 0 : Text {
                                text: "Firefox → about:debugging → 'Conectar' → localhost:\{root.dev-rdp-port} → Inspecionar a aba.";
                                color: Theme.ok;
                                font-family: "monospace";
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                            if root.dev-rdp-port == 0 : Text {
                                text: "Servidor RDP desligado. Reinicie com: BASEDBROWSER_DEVTOOLS=7000 cargo run -p basedbrowser";
                                color: Theme.text-mid;
                                font-size: 12px;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // Aba CONSOLE: lista de mensagens + REPL de eval.
                    if root.dev-tab == 0 : VerticalLayout {
                        spacing: 8px;
                        ListView {
                            for c in root.dev-console : HorizontalLayout {
                                padding-left: 8px;
                                padding-top: 3px;
                                padding-bottom: 3px;
                                spacing: 10px;
                                alignment: start;
                                // Nível (coluna fixa, monospace, alinhado ao topo p/ linhas multilinha).
                                Text {
                                    text: c.level;
                                    width: 52px;
                                    font-family: "monospace";
                                    font-size: 11px;
                                    vertical-alignment: top;
                                    color: c.level == "error" ? Theme.danger
                                        : c.level == "warn" ? #ffd47a
                                        : c.level == "result" ? Theme.ok
                                        : c.level == "eval" ? #9ab8ff
                                        : Theme.text-mid;
                                }
                                // Texto monospace que QUEBRA (resultados multilinha legíveis); a linha
                                // cresce em altura (ListView mede cada item).
                                Text {
                                    text: c.text;
                                    font-family: "monospace";
                                    font-size: 12px;
                                    color: Theme.text-hi;
                                    wrap: word-wrap;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                        evalfield := SearchField {
                            mono: true;
                            placeholder: "Avaliar JavaScript e teclar Enter (ex.: document.title)";
                            accepted(t) => {
                                root.dev-eval(t);
                                evalfield.text = "";
                            }
                        }
                    }

                    // Aba REDE (M10): filtro + cabeçalho de colunas + lista (Método/Status/Nome/Tipo) +
                    // detalhe com sub-abas Request/Response. Tudo que é dado de rede em monospace.
                    if root.dev-tab == 1 : VerticalLayout {
                        spacing: 6px;
                        // Filtro (substring sobre URL/método/status/nome — aplicado no Rust).
                        SearchField {
                            placeholder: "Filtrar (URL, método, status)…";
                            edited(t) => { root.search-devtools(t); }
                        }
                        // Chips de TIPO (M10): separa as requests "de verdade" (XHR/fetch) do ruído
                        // (imagens, fontes, css...). Índices casam com net_kind no Rust.
                        HorizontalLayout {
                            spacing: 4px;
                            alignment: start;
                            for chip[idx] in ["Tudo", "XHR", "Doc", "JS", "CSS", "Img", "Fonte", "Outros"] : Chip {
                                label: chip;
                                active: root.dev-net-kind == idx;
                                clicked => {
                                    root.dev-net-kind = idx;
                                    root.filter-net-kind(idx);
                                }
                            }
                        }
                        // Cabeçalho de colunas (espelha a lista abaixo).
                        HorizontalLayout {
                            padding-left: 8px;
                            spacing: 10px;
                            Text {
                                text: "Método";
                                width: 56px;
                                font-size: 11px;
                                color: Theme.text-lo;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "Status";
                                width: 64px;
                                font-size: 11px;
                                color: Theme.text-lo;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "Nome";
                                horizontal-stretch: 1;
                                font-size: 11px;
                                color: Theme.text-lo;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "Tipo";
                                width: 48px;
                                font-size: 11px;
                                color: Theme.text-lo;
                                vertical-alignment: center;
                            }
                            Text {
                                text: "Tamanho";
                                width: 64px;
                                font-size: 11px;
                                color: Theme.text-lo;
                                vertical-alignment: center;
                            }
                        }
                        ListView {
                            for n[idx] in root.dev-net : Rectangle {
                                height: 24px;
                                border-radius: Theme.radius-btn;
                                background: ntouch.has-hover || root.dev-net-sel == idx ? Theme.bg-elevated : transparent;
                                ntouch := TouchArea {
                                    mouse-cursor: pointer;
                                    clicked => { root.dev-net-sel = idx; }
                                }
                                HorizontalLayout {
                                    padding-left: 8px;
                                    spacing: 10px;
                                    Text {
                                        text: n.method;
                                        width: 56px;
                                        font-family: "monospace";
                                        font-size: 12px;
                                        color: #9ab8ff;
                                        vertical-alignment: center;
                                    }
                                    // Status colorido por classe: 2xx ok, 3xx âmbar, 4xx/5xx erro.
                                    Text {
                                        text: n.status == "" ? "…" : n.status;
                                        width: 64px;
                                        font-family: "monospace";
                                        font-size: 12px;
                                        color: n.status-class == 2 ? Theme.ok
                                            : n.status-class == 3 ? #ffd47a
                                            : n.status-class >= 4 ? Theme.danger
                                            : Theme.text-mid;
                                        overflow: elide;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: n.name;
                                        horizontal-stretch: 1;
                                        font-family: "monospace";
                                        font-size: 12px;
                                        color: Theme.text-hi;
                                        overflow: elide;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: n.kind-label;
                                        width: 48px;
                                        font-family: "monospace";
                                        font-size: 12px;
                                        color: n.kind-label == "xhr" ? Theme.accent : Theme.text-mid;
                                        overflow: elide;
                                        vertical-alignment: center;
                                    }
                                    Text {
                                        text: n.size;
                                        width: 64px;
                                        font-family: "monospace";
                                        font-size: 12px;
                                        color: Theme.text-mid;
                                        overflow: elide;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                        // Detalhe da requisição selecionada: URL completa + sub-abas Request/Response.
                        if root.dev-net-sel >= 0 && root.dev-net-sel < root.dev-net.length : VerticalLayout {
                            spacing: 6px;
                            Text {
                                text: "▸ " + root.dev-net[root.dev-net-sel].method + " " + root.dev-net[root.dev-net-sel].url;
                                font-family: "monospace";
                                font-size: 12px;
                                color: Theme.text-hi;
                                wrap: word-wrap;
                            }
                            Text {
                                text: "Status: " + (root.dev-net[root.dev-net-sel].status == "" ? "pendente" : root.dev-net[root.dev-net-sel].status)
                                    + " · " + root.dev-net[root.dev-net-sel].kind-label
                                    + (root.dev-net[root.dev-net-sel].mime == "" ? "" : " · " + root.dev-net[root.dev-net-sel].mime)
                                    + (root.dev-net[root.dev-net-sel].size == "" ? "" : " · " + root.dev-net[root.dev-net-sel].size)
                                    + (root.dev-net[root.dev-net-sel].time == "" ? "" : " · " + root.dev-net[root.dev-net-sel].time);
                                font-family: "monospace";
                                font-size: 12px;
                                color: root.dev-net[root.dev-net-sel].status-class == 2 ? Theme.ok
                                    : root.dev-net[root.dev-net-sel].status-class >= 4 ? Theme.danger
                                    : Theme.text-mid;
                            }
                            HorizontalLayout {
                                spacing: 6px;
                                alignment: start;
                                TextBtn {
                                    label: "Request";
                                    active: root.dev-net-detail-tab == 0;
                                    clicked => { root.dev-net-detail-tab = 0; }
                                }
                                TextBtn {
                                    label: "Response";
                                    active: root.dev-net-detail-tab == 1;
                                    clicked => { root.dev-net-detail-tab = 1; }
                                }
                            }
                            ScrollView {
                                height: 40%;
                                VerticalLayout {
                                    padding: 8px;
                                    spacing: 4px;
                                    alignment: start;
                                    if root.dev-net-detail-tab == 0 : VerticalLayout {
                                        spacing: 4px;
                                        alignment: start;
                                        Text {
                                            text: "— Request headers —";
                                            font-size: 12px;
                                            color: Theme.text-mid;
                                        }
                                        Text {
                                            text: root.dev-net[root.dev-net-sel].req-headers;
                                            font-family: "monospace";
                                            font-size: 12px;
                                            color: Theme.text-hi;
                                            wrap: word-wrap;
                                        }
                                        Text {
                                            text: "— Payload —";
                                            font-size: 12px;
                                            color: Theme.text-mid;
                                        }
                                        Text {
                                            text: root.dev-net[root.dev-net-sel].req-body == "" ? "(sem payload)" : root.dev-net[root.dev-net-sel].req-body;
                                            font-family: "monospace";
                                            font-size: 12px;
                                            color: root.dev-net[root.dev-net-sel].req-body == "" ? Theme.text-lo : Theme.text-hi;
                                            wrap: word-wrap;
                                        }
                                    }
                                    if root.dev-net-detail-tab == 1 : VerticalLayout {
                                        spacing: 4px;
                                        alignment: start;
                                        Text {
                                            text: "— Response headers —";
                                            font-size: 12px;
                                            color: Theme.text-mid;
                                        }
                                        Text {
                                            text: root.dev-net[root.dev-net-sel].resp-headers;
                                            font-family: "monospace";
                                            font-size: 12px;
                                            color: Theme.text-hi;
                                            wrap: word-wrap;
                                        }
                                        Text {
                                            text: "— Body —";
                                            font-size: 12px;
                                            color: Theme.text-mid;
                                        }
                                        Text {
                                            text: root.dev-net[root.dev-net-sel].body;
                                            font-family: "monospace";
                                            font-size: 12px;
                                            color: Theme.text-hi;
                                            wrap: word-wrap;
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
